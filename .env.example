# Provider mode.
# mock is deterministic and requires no network or API keys.
# MARKET_DATA_MODE: mock, live, auto, or yahoo.
# NEWS_DATA_MODE: mock, live, auto, or multi.
MARKET_DATA_MODE=mock
NEWS_DATA_MODE=mock

# Comma-separated sources used when NEWS_DATA_MODE=multi.
NEWS_SOURCES=yahoo,newsapi,google

# Used when MARKET_DATA_MODE is live or auto.
ALPHA_VANTAGE_API_KEY=

# Used when NEWS_DATA_MODE is live, auto, or multi with newsapi enabled.
NEWSAPI_API_KEY=

# Output directory for generated HTML and JSON artifacts.
OUTPUT_DIR=outputs

# Defaults to false. Set true to keep timestamped briefing_*.html/json archives.
KEEP_HISTORY=false

# Optional SMTP settings for --send-email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true
